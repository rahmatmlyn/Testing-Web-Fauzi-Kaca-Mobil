# ============================================================================
# ENVIRONMENT VARIABLES — Fauzi Kaca Mobil
# ============================================================================
# Copy file ini menjadi `.env` (jangan di-commit!) lalu isi nilai aslinya.
# File `.env` ada di .gitignore — credential aman tidak ke-push ke GitHub.

# ----------------------------------------------------------------------------
# SITE INFO (opsional — bisa juga di-edit langsung di src/js/config.js)
# ----------------------------------------------------------------------------
VITE_SITE_URL=https://fauzikacamobil.com
VITE_WHATSAPP_NUMBER=6281234567890
VITE_PHONE=+62-812-3456-7890
VITE_EMAIL=info@fauzikacamobil.com

# ----------------------------------------------------------------------------
# ANALYTICS (untuk monitoring traffic — opsional)
# ----------------------------------------------------------------------------
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FB_PIXEL_ID=
VITE_HOTJAR_ID=

# ----------------------------------------------------------------------------
# FTP DEPLOYMENT (untuk GitHub Actions auto-deploy ke Domainesia)
# ----------------------------------------------------------------------------
# JANGAN commit nilai asli — set di GitHub Secrets!
# Settings → Secrets and variables → Actions → New repository secret
FTP_HOST=ftp.fauzikacamobil.com
FTP_USERNAME=cpanel_username
FTP_PASSWORD=cpanel_password
FTP_REMOTE_PATH=/public_html/

# ----------------------------------------------------------------------------
# MAPS (jika butuh API key Google Maps)
# ----------------------------------------------------------------------------
VITE_GOOGLE_MAPS_API_KEY=
