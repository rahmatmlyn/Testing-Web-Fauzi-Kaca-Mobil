jspm_packages/
.pnp.*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Lock files (pilih salah satu untuk di-commit)
# npm:        commit package-lock.json
# yarn:       commit yarn.lock
# pnpm:       commit pnpm-lock.yaml
# Default kita pakai npm — jadi yarn.lock & pnpm-lock.yaml di-ignore
yarn.lock
pnpm-lock.yaml

